# =============================================================================
# knowledge-engineering 环境变量样本
# =============================================================================
# 用法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 填入真实 secret（**绝不**提交 .env 到 git，已被 .gitignore 排除）
#   3. 启动方式：
#        - 开发：source .env 后运行 python -m src.pipeline.cli ...
#        - 生产：systemd EnvironmentFile=/opt/knowledge-engineering/.env
#
# 与本仓库绑定的 secret 渠道：
#   - 阿里通义百炼控制台（embedding）：https://bailian.console.aliyun.com/?apiKey=1
#   - OpenAI / Anthropic（LLM 解读）：各自官网创建 API Key
# =============================================================================

# ----- 语义 embedding（默认 backend = dashscope） -----
# 在 config/project.yaml 中：knowledge.semantic_embedding.backend = dashscope
# 调用阿里通义 text-embedding-v4，OpenAI 兼容接口
DASHSCOPE_API_KEY=sk-your-key-here

# ----- LLM 解读（按需开通；当前 LLMProviderFactory 支持） -----
# OpenAI（method/business 解读时若 llm_backend=openai）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Anthropic（method/business 解读时若 llm_backend=anthropic）
# ANTHROPIC_API_KEY=

# ----- Weaviate（如启用 vectordb-* 且开 API key 鉴权） -----
# 当前实例配置在 config/project.yaml::knowledge.vectordb-* 段直接传 weaviate_api_key
# 后续若改为环境变量读取再启用此项
# WEAVIATE_API_KEY=

# ----- Neo4j 连接（如不放 yaml） -----
# 当前 config/project.yaml::knowledge.graph 直接配 neo4j_uri/user/password
# 生产环境建议改成环境变量后启用此项
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# =============================================================================
# 登录与认证 (Phase 4 — 详见 [[登录与认证-设计]])
# =============================================================================

# DB 连接（asyncmy 驱动）
KE_DB_URL=mysql+asyncmy://ke_app:CHANGE_ME@localhost:3306/knowledge_engineering

# JWT secret，生产环境用 `openssl rand -hex 32` 生成 64 字符 hex
KE_JWT_SECRET=replace-with-32-byte-hex
KE_JWT_ALGORITHM=HS256
KE_JWT_ACCESS_TTL_MIN=60
KE_JWT_REFRESH_TTL_DAYS=1
KE_JWT_REFRESH_TTL_REMEMBER_DAYS=7

# Cookie scope（生产应该是 https 路径）
KE_COOKIE_DOMAIN=
KE_COOKIE_SECURE=true
KE_COOKIE_SAMESITE=strict
# cookie path: 直接 :8000/auth/* 时 = "/auth"；经 nginx /api/* 反代时 = "/api/auth"
# 本地 dev（vite proxy）= "/api/auth"；本地 dev 时 KE_COOKIE_SECURE 改 false / KE_COOKIE_SAMESITE 改 lax
KE_COOKIE_PATH=/api/auth
